<div class="prose box palette-copper palette-low-contrast font-bold">
  <form class="flow" action="https://reperes-contact.val.run/" method="post">
    <label for="name">Nom</label>
    <input type="text" id="name" name="name" required />
    <label for="email">Email</label>
    <input type="email" id="email" name="email" required />
    <label for="topic">Sujet</label>
    <input type="text" id="topic" name="topic" required />
    <label for="message">Message</label>
    <textarea id="message" name="message" required></textarea>
    <input
      name="username"
      id="username"
      placeholder="Username"
      type="text"
      tabindex="-1"
      autocomplete="one-time-code"
      class="hp"
    />
    <input
      id="formname"
      name="formname"
      type="text"
      value="Contact Repères"
      style="display: none"
    />
    <button type="submit" class="align-self-start">Envoyer</button>
  </form>
</div>

{% css %}

form .hp {
  position: absolute;
  left: -99999px;
}
label:has(+ [required]) {
  &::after {
    content: " *";
  }
}
:is(input, textarea):user-invalid {
  outline: 2px solid var(--vermilion);
}

{% endcss %}
